# Configuração do Firebase — MESMO projeto do site (mesmo banco).
# Copie este arquivo para ".env.local" e preencha com os valores REAIS do seu
# Firebase (Console → Configurações do projeto → Seus apps → Config do app Web).
# São os MESMOS valores que o site usa na Vercel. Esses dados do Firebase Web
# são públicos por natureza (não são segredo) — é seguro usá-los no app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
